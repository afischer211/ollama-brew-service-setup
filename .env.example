# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Address and port the Ollama server listens on (default: 127.0.0.1:11434)
OLLAMA_HOST=0.0.0.0:11434

# Comma-separated allowed cross-origin domains (default: localhost, 127.0.0.1, 0.0.0.0)
#OLLAMA_ORIGINS=192.168.1.*

# Directory where models are stored (default: ~/.ollama/models)
#OLLAMA_MODELS=~/.ollama/models

# Allowed hosts for remote model access (default: ollama.com)
#OLLAMA_REMOTES=ollama.com

# Disable Ollama cloud features, set to 1 to disable (default: disabled)
#OLLAMA_NO_CLOUD=1

# Enable authentication between client and server (default: disabled)
#OLLAMA_AUTH=

# ---------------------------------------------------------------------------
# Model lifecycle
# ---------------------------------------------------------------------------

# How long a model stays loaded after last use — Go duration, -1 = forever, 0 = unload immediately (default: 5m)
# M1 Pro/Max 32GB+: set to -1 or a long duration (e.g. 1h) — unified memory is large enough to keep models resident
#OLLAMA_KEEP_ALIVE=5m

# Maximum time a model load may stall before being abandoned (default: 5m)
#OLLAMA_LOAD_TIMEOUT=5m

# ---------------------------------------------------------------------------
# Context & concurrency
# ---------------------------------------------------------------------------

# Default context window size in tokens (default: auto based on available VRAM)
# M1 Pro/Max 32GB+: 8192–16384 is comfortable for 7B–13B models; 32768 feasible for smaller ones
OLLAMA_CONTEXT_LENGTH=4096

# Maximum number of models loaded simultaneously (default: 0 = unlimited)
# M1 Pro/Max 32GB+: 2–3 quantized models fit easily (e.g. two 7B Q4 models use ~4–5 GB each)
OLLAMA_MAX_LOADED_MODELS=1

# Maximum number of parallel requests per model (default: 1)
# M1 Pro/Max 32GB+: 2–4 — Pro has 16 GPU cores, Max has 32, both handle concurrent requests well
OLLAMA_NUM_PARALLEL=1

# Maximum number of queued requests before returning 503 (default: 512)
#OLLAMA_MAX_QUEUE=512

# ---------------------------------------------------------------------------
# GPU & performance
# ---------------------------------------------------------------------------

# Reserve VRAM per GPU in bytes to avoid OOM (default: 0)
# M1 Pro/Max 32GB+: not needed — macOS manages unified memory dynamically
#OLLAMA_GPU_OVERHEAD=0

# Schedule models across all GPUs instead of filling one first (default: disabled)
# M1 Pro/Max: leave disabled — there is only one unified GPU
OLLAMA_SCHED_SPREAD=0

# Enable Flash Attention for reduced memory usage, set to 1 (default: disabled)
# M1 Pro/Max 32GB+: enable — well-supported on Metal, reduces memory pressure noticeably
OLLAMA_FLASH_ATTENTION=1

# KV cache quantization type: f16, q8_0, q4_0 (default: f16)
# M1 Pro/Max 32GB+: q8_0 halves KV cache memory vs f16 with negligible quality loss, freeing room for larger contexts
OLLAMA_KV_CACHE_TYPE=q8_0

# Optimize prompt caching for multi-user scenarios, set to 1 (default: disabled)
# M1 Pro/Max 32GB+: enable if multiple clients hit the server concurrently (e.g. Open WebUI + CLI)
#OLLAMA_MULTIUSER_CACHE=1

# Override automatic LLM library detection with an explicit path (default: auto)
#OLLAMA_LLM_LIBRARY=

# Enable experimental Vulkan GPU support, set to 1 (default: disabled)
# M1 Pro/Max: do NOT enable — macOS uses Metal, not Vulkan
#OLLAMA_VULKAN=1

# Enable experimental new Ollama engine, set to 1 (default: disabled)
#OLLAMA_NEW_ENGINE=1

# ---------------------------------------------------------------------------
# Debugging & logging
# ---------------------------------------------------------------------------

# Log verbosity level: DEBUG, INFO, WARN, ERROR (default: INFO)
#OLLAMA_DEBUG=INFO

# Log full request bodies and generate replay curl commands, set to 1 (default: disabled)
#OLLAMA_DEBUG_LOG_REQUESTS=1

# Suppress saving readline command history, set to 1 (default: disabled)
#OLLAMA_NOHISTORY=1

# Skip pruning of unused model blobs on startup, set to 1 (default: disabled)
#OLLAMA_NOPRUNE=1

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# HTTPS proxy for outbound requests (e.g. model downloads)
#HTTPS_PROXY=
